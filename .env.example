# Database
DB_URL=jdbc:postgresql://localhost:5432/name_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT
JWT_SECRET=yoursupersecretjwtkeymin256dfdsfdsbits
JWT_EXPIRATION=3600000
JWT_ISSUER=gaira-api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Authentication
AUTH_REFRESH_EXPIRATION_SECONDS=604800
AUTH_MAX_FAILED_ATTEMPTS=5

# Seed (Admin)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin_password
SEED_ADMIN_EMAIL=you_email@example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
THROTTLE_CAPACITY=10
THROTTLE_REFILL_TOKENS=10
THROTTLE_REFILL_SECONDS=60

# Redis / Valkey
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SMTP)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
# Use Gmail App Password (16 chars), without quotes and without spaces.
# Example valid format: abcdwxyzpqrsuvmn
SPRING_MAIL_PASSWORD=yourgmailapppassword
# Recommended: same address as SPRING_MAIL_USERNAME to avoid SMTP rejections.
SPRING_MAIL_FROM=your_email@gmail.com
SPRING_MAIL_GROUP_COPY=restobar_lagaira@googlegroups.com
