# Database
DB_URL=jdbc:postgresql://localhost:5432/name_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT
JWT_SECRET=yoursupersecretjwtkeymin256_bits
JWT_EXPIRATION=3600000
JWT_ISSUER=gaira-api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Authentication
AUTH_REFRESH_EXPIRATION_SECONDS=604800
AUTH_MAX_FAILED_ATTEMPTS=5

# Seed (Admin)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin_password
SEED_ADMIN_EMAIL=you_email@example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
THROTTLE_CAPACITY=10
THROTTLE_REFILL_TOKENS=10
THROTTLE_REFILL_SECONDS=60