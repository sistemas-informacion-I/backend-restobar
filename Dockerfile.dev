# Backend Dockerfile for Development - Spring Boot with hot-reload
FROM eclipse-temurin:21-jdk-alpine

WORKDIR /app

# Instalar curl para health checks
RUN apk add --no-cache curl

# Copy gradle files
COPY gradle/ gradle/
COPY gradlew gradlew.bat ./
COPY build.gradle settings.gradle ./

# Make gradle executable
RUN chmod +x gradlew

# Copy source code
COPY src ./src

# Expose port
EXPOSE 3000

# Run Spring Boot in development mode (hot-reload enabled)
CMD ["./gradlew", "bootRun", "--no-daemon", "-Dspring-boot.run.jvmArguments=-Dfile.encoding=UTF-8"]
